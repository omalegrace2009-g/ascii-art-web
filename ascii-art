package main

import (
	"fmt"
	"os"
	"strings"
)

// READ THE BANER FILE
func readBanner(filename string) ([]string, error) {
	content, err := os.ReadFile(filename)
	if err != nil {
		return nil, err
	}
	lines := strings.Split(string(content), "\n")
	return lines, nil
}

