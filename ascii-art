func main() {
	if len(os.Args) != 2 {        
		fmt.Println("usage: go run . [string]")
		return
	}
	input := os.Args[1]
	lines := strings.Split(input, "\\n")
	for _, d := range lines {
		fmt.Println(d)
	}
	bannerLines, err := readBanner("banner/standard.txt")
	if err != nil {
		fmt.Println("Error reading file: ", err)
		return
	}
	dlines := getLines(bannerLines, []rune(input))
	for _, line := range dlines {
